# Supabase (required)
VITE_SUPABASE_URL=your_supabase_url_here
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Public site URL for SEO (canonical, OG, sitemap)
VITE_SITE_URL=https://your-site-domain.com

# E2E test mode — only set true in CI/staging, never in public production
# VITE_ENABLE_TEST_MODE=false

# WebRTC TURN server (Metered.ca or similar)
VITE_TURN_URL=turn:your-turn-server.example.com:80
VITE_TURN_URL_SSL=turn:your-turn-server.example.com:443
VITE_TURN_USERNAME=your_turn_username_here
VITE_TURN_PASSWORD=your_turn_password_here

# TMDB API (optional, for movie/TV recommendations)
# VITE_TMDB_API_KEY=your_tmdb_api_key_here

# Sentry error tracking (optional)
# VITE_SENTRY_DSN=your_sentry_dsn_here
# VITE_SENTRY_CDN=https://browser.sentry-cdn.com/7.63.0/bundle.min.js

# App version (optional)
# VITE_APP_VERSION=1.0.0
