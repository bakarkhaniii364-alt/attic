# Supabase (required for production builds)
VITE_SUPABASE_URL=your_supabase_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# Public site URL for SEO (canonical, OG, sitemap)
VITE_SITE_URL=https://attic.app

# E2E test mode — only set true in CI/staging, never in public production
# VITE_ENABLE_TEST_MODE=false

# WebRTC TURN (Metered.ca or similar)
VITE_TURN_URL=turn:relay.metered.ca:80
VITE_TURN_URL_SSL=turn:relay.metered.ca:443
VITE_TURN_USERNAME=your_turn_username
VITE_TURN_PASSWORD=your_turn_password
